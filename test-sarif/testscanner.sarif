{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "TestScanner",
          "informationUri": "https://example.com",
          "rules": [
            {
              "id": "CWE-89",
              "shortDescription": {"text": "SQL Injection"},
              "properties": {"cwe": ["CWE-89"]}
            },
            {
              "id": "CWE-79",
              "shortDescription": {"text": "Cross-site Scripting"},
              "properties": {"cwe": ["CWE-79"]}
            },
            {
              "id": "CWE-78",
              "shortDescription": {"text": "OS Command Injection"},
              "properties": {"cwe": ["CWE-78"]}
            },
            {
              "id": "CWE-94",
              "shortDescription": {"text": "Code Injection"},
              "properties": {"cwe": ["CWE-94"]}
            },
            {
              "id": "CWE-502",
              "shortDescription": {"text": "Deserialization of Untrusted Data"},
              "properties": {"cwe": ["CWE-502"]}
            },
            {
              "id": "CWE-639",
              "shortDescription": {"text": "Authorization Bypass"},
              "properties": {"cwe": ["CWE-639"]}
            },
            {
              "id": "CWE-250",
              "shortDescription": {"text": "Execution with Unnecessary Privileges"},
              "properties": {"cwe": ["CWE-250"]}
            },
            {
              "id": "CWE-915",
              "shortDescription": {"text": "Mass Assignment"},
              "properties": {"cwe": ["CWE-915"]}
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "CWE-89",
          "level": "error",
          "message": {"text": "SQL Injection: User input flows into SQL query"},
          "locations": [{
            "physicalLocation": {
              "artifactLocation": {"uri": "reflection-testbed/python/app.py"},
              "region": {"startLine": 42, "endLine": 43}
            }
          }]
        },
        {
          "ruleId": "CWE-79",
